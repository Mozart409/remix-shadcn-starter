{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noForEach": "off"
      }
    },
    "includes": ["**", "!**/node_modules", "!**/build", "!**/.cache", "!**/.git"]
  },
  "css": { "parser": { "cssModules": false, "tailwindDirectives": true }, "linter": { "enabled": true }, "formatter": { "enabled": true } },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120,
    "includes": ["**", "!**/node_modules", "!**/build", "!**/.cache", "!**/.git", "!**/.yaml", "!**/.json", "!**/.svg"],
    "formatWithErrors": true
  }
}

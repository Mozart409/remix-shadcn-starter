{
  "name": "remix-shadcn-starter",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "version": "0.1.3",
  "scripts": {
    "build": "remix vite:build",
    "dev": "remix vite:dev",
    "fmt": "biome format . --write ./app",
    "image": "docker build -t remix-shadcn-starter:latest .",
    "lint": "biome check --write ./app",
    "start": "remix-serve ./build/server/index.js",
    "typecheck": "tsc",
    "up": "docker compose up -d --build --remove-orphans",
    "watch": "docker compose watch",
    "down": "docker compose down"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "@remix-run/node": "^2.17.4",
    "@remix-run/react": "^2.17.4",
    "@remix-run/serve": "^2.17.4",
    "@types/invariant": "^2.2.37",
    "build": "^0.1.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "invariant": "^2.2.4",
    "isbot": "^5.1.37",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remix-themes": "^2.0.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@remix-run/dev": "^2.17.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "remix-development-tools": "^4.7.7",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.5",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}

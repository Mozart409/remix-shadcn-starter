{
  "name": "remix-shadcn-starter",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "version": "0.2.0",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "fmt": "biome format . --write ./app",
    "image": "podman build -t remix-shadcn-starter:latest .",
    "lint": "biome check --write ./app",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "up": "podman-compose up -d --build --remove-orphans",
    "watch": "podman-compose watch",
    "down": "podman-compose down"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-navigation-menu": "^1.2.16",
    "@radix-ui/react-slot": "^1.3.0",
    "@react-router/node": "^8.0.0",
    "@react-router/serve": "^8.0.0",
    "@types/invariant": "^2.2.37",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "invariant": "^2.2.4",
    "isbot": "^5.1.43",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.0.0",
    "remix-themes": "^2.0.4",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@react-router/dev": "^8.0.0",
    "@react-router/fs-routes": "^8.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=22.0.0"
  }
}

{
  "name": "remix-shadcn-starter",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "version": "0.2.0",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "fmt": "biome format . --write ./app",
    "image": "docker build -t remix-shadcn-starter:latest .",
    "lint": "biome check --write ./app",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "up": "docker compose up -d --build --remove-orphans",
    "watch": "docker compose watch",
    "down": "docker compose down"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-router/node": "^7.6.1",
    "@react-router/serve": "^7.6.1",
    "@types/invariant": "^2.2.37",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "invariant": "^2.2.4",
    "isbot": "^5.1.37",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.6.1",
    "remix-themes": "^2.0.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@react-router/dev": "^7.6.1",
    "@react-router/fs-routes": "^7.6.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.5"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  }
}
